{"apiVersion":"agent-sim/v1","kind":"Scenario","metadata":{"id":"character-impatient","locale":"en-US","tags":["example","character"]}}
{"kind":"Persona","spec":{"name":"Sam","language":"en-US","brief":"You called support about a delayed order. You are short on time.","goals":["Confirm you reached support","State the order is delayed and ask for ETA or next step","End politely once you have a clear next step"],"style":"short answers, slightly rushed","traits":["impatient","interrupts","polite"],"constraints":["Do not invent payment card numbers","Do not agree to restart from the main menu — ask for a supervisor or hang up with [END_CALL]"],"speech_conditions":{"barge_policy":"mid_agent_turn","barge_after_agent_ms":700,"barge_say":"Sorry — I only have a minute — what's the ETA?","noise":"","silence_ms":0}}}
{"kind":"Execute","spec":{"max_turns":6,"timeout_s":150,"first_speaker":"agent"}}
{"kind":"Assert","spec":{"tools":[],"transcript":[{"role":"agent","contains_any":["help","hello","hi","support","order","sorry"]}],"outcomes":[{"id":"recovered","type":"recovery","min_agent_finals_after_barge_in":1,"min_interruptions":0}]}}
{"kind":"PassCriteria","spec":{"criteria":["The agent responded to an impatient caller","The agent stayed on the delayed-order topic"]}}
