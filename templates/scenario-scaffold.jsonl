// === Scenario (required header — first JSON line) ===
// apiVersion: must be "agent-sim/v1"
// metadata.id: same as this filename (without .jsonl)
// metadata.locale: BCP-47 language for the sim persona (e.g. en-US, vi-VN, ja-JP)
// metadata.tags: free labels; use with: lks execute-all --tag smoke
{"apiVersion":"agent-sim/v1","kind":"Scenario","metadata":{"id":"{{SCENARIO_ID}}","locale":"en-US","tags":["draft"]}}
// === Persona (required) — Hamming-style character ===
// name, brief (required), goals[], style, traits[]
// constraints[]: hard rules (no card numbers, hang up if restart menu, …)
// speech_conditions: optional auto Script — barge_policy, noise/noise_when/noise_gain, silence_ms, voice_gain (quiet mic; NO voice_speed on Gemini Live)
// speech_conditions: optional auto Script — barge_policy, noise/noise_when/noise_gain, silence_ms, silent_mode (whole-call mute), voice_gain if present
// language: optional override of metadata.locale for speech
{"kind":"Persona","spec":{"name":"Alex","brief":"You are calling a business for the first time. Confirm you reached the right place, answer briefly, then politely end the call when done.","goals":["Hear the agent greeting or first reply","State your reason briefly","End the call politely"],"style":"polite, brief, natural spoken language","traits":["polite"],"constraints":["Do not invent account numbers or payment details"],"speech_conditions":{"barge_policy":"","noise":"","silence_ms":0}}}
// === Context (optional) ===
// notes + optional fixtures (opaque hints for humans/seed; not parsed by core)
{"kind":"Context","spec":{"notes":"Example: open ticket #12345. Prefer deleting this line over leaving fake notes.","fixtures":{}}}
// === Simulator / Execute ===
{"kind":"Simulator","spec":{"max_turns":6,"timeout_s":120,"first_speaker":"agent"}}
{"kind":"Execute","spec":{"max_turns":4,"timeout_s":120,"first_speaker":"user"}}
// === Dispatch (optional) — opaque JSON string for RoomAgentDispatch.metadata ===
{"kind":"Dispatch","spec":{"metadata":"{\"yourProjectKey\":\"replace-me\"}"}}
// === Caller / Telephony (optional) — transport mode; NEVER put mode in config.yaml ===
// mode: webrtc_sim (default) | inbound_sip | outbound_human_pickup | outbound_sim_callee | agent_dials
// outbound_human_pickup:        human answers — need Telephony.call_to (handset) + trunk
// outbound_sim_callee: Gemini answers — need call_to OR config sim_inbound_number + trunk + DID dispatch
// inbound_sip:         Gemini dials  — need dial_in OR config telephony.dial_in + trunk
// See docs/telephony.md and templates/outbound-human-pickup.jsonl / outbound-callee-sim.jsonl / inbound-caller-sim.jsonl
// {"kind":"Caller","spec":{"mode":"webrtc_sim"}}
// {"kind":"Telephony","spec":{"call_to":"+15559876543","dial_in":"+15551234567","prepare_ms":3000}}
// === Behavior (optional, Hamming policy) — compiles to Script if present ===
// barge_ins[], user_silence[], hang_ups[], ambient{asset,delay_ms}
// Explicit Script below wins on same step id
// {"kind":"Behavior","spec":{"barge_ins":[{"id":"cut1","after_agent_ms":800,"say":"Wait — one second","class":"correction","with_blip":true}],"backchannels":[{"id":"uh1","after_agent_ms":1200,"asset":"builtin:voice.backchannel"}],"false_interrupts":[{"id":"n1","after_agent_ms":400,"asset":"builtin:noise.loud"}],"ambient":{"asset":"builtin:noise.ambient","delay_ms":1500,"loop":true,"gain":0.3}}}
// === Script (optional) — timed cues; omit if speech_conditions/Behavior enough ===
// trigger: agent_speaking | silence | time
// action: speak | wait | hang_up
// barge_in + with_blip (default true for gemini_text)
// asset: builtin:voice.barge_short | builtin:noise.loud | .agent-sim/cues/file.wav
// speech_conditions.barge_asset: builtin:voice.barge_short (vocal; with_blip defaults off for voice.*)
// {"kind":"Script","spec":{"steps":[],"verify":{"require_during_agent_speech":false,"min_agent_finals_after_barge_in":0}}}
// === Assert — tools / transcript / outcomes / sip ===
// tool_order: ["lookup_identity","list_items"]  # required subsequence of tool.start names
// latency example: {"id":"speed","type":"latency","max_turn_p95_ms":3500,"max_ttfw_ms":5000,"require_turn_samples":1}
// ended_by example: {"id":"caller_hung_up","type":"ended_by","who":"sim"}
// constraint_respected: {"id":"no_card","type":"constraint_respected","must_not_phrases":["4111","card number"]}
// sip example: "sip":{"participant_present":true,"dial_answered":true,"call_status_any":["active"]}
{"kind":"Assert","spec":{"tools":[],"transcript":[{"role":"agent","contains_any":["help","support","hello","hi"]}],"outcomes":[{"id":"agent_spoke","type":"transcript_contains","role":"agent","phrases":["a","e","i","o","u"]}]}}
// === PassCriteria (optional soft judge) ===
{"kind":"PassCriteria","spec":{"criteria":["The agent responded to the caller","The agent responded in a language the caller can understand"]}}
