// === Scenario (required header — first JSON line) ===
// apiVersion: must be "agent-sim/v1"
// metadata.id: same as this filename (without .jsonl)
// metadata.locale: BCP-47 language for the sim persona (e.g. en-US, vi-VN, ja-JP)
// metadata.tags: free labels; use with: lk-sim execute-all --tag smoke
{"apiVersion":"agent-sim/v1","kind":"Scenario","metadata":{"id":"{{SCENARIO_ID}}","locale":"en-US","tags":["draft"]}}
// === Persona (required) ===
// name, brief (required), goals[], style
// traits[]: behavior tags e.g. impatient, interrupts, quiet (injected into sim system prompt)
// language: optional override of metadata.locale for speech
{"kind":"Persona","spec":{"name":"Alex","brief":"You are calling a business for the first time. Confirm you reached the right place, answer briefly, then politely end the call when done.","goals":["Hear the agent greeting or first reply","State your reason briefly","End the call politely"],"style":"polite, brief, natural spoken language","traits":["polite"]}}
// === Context (optional) — delete this comment block and the next JSON line if unused ===
// notes: extra facts injected into the persona prompt
{"kind":"Context","spec":{"notes":"Example: open ticket #12345. Prefer deleting this line over leaving fake notes."}}
// === Simulator (optional defaults) — Execute overrides these ===
// max_turns, timeout_s, first_speaker: agent | user
{"kind":"Simulator","spec":{"max_turns":6,"timeout_s":120,"first_speaker":"agent"}}
// === Execute (recommended run knobs; overrides Simulator) ===
{"kind":"Execute","spec":{"max_turns":4,"timeout_s":120,"first_speaker":"user"}}
// === Dispatch (optional) — opaque JSON string for RoomAgentDispatch.metadata ===
{"kind":"Dispatch","spec":{"metadata":"{\"yourProjectKey\":\"replace-me\"}"}}
// === Script (optional) — timed behavior while agent talks / silence ===
// trigger: agent_speaking | silence | time
// action: speak (default) | wait (no audio; for silence / "user gone")
// barge_in: true → short delay barge-in while agent_speaking
// delivery: gemini_text | room_pcm (+ asset)
// asset: builtin:noise.loud | @noise.ambient | file in .agent-sim/cues/ | cues.aliases name
// lk-sim cues --root .   # list built-in + target overrides
// verify.min_interruptions / min_agent_finals_after_silence / …
{"kind":"Script","spec":{"steps":[{"id":"example-backchannel","trigger":"agent_speaking","delay_ms":800,"say":"uh-huh","label":"backchannel","delivery":"gemini_text","once":true},{"id":"example-noise","trigger":"time","delay_ms":5000,"delivery":"room_pcm","asset":"builtin:noise.loud","say":"[noise]","label":"optional-noise","once":true},{"id":"example-silence","trigger":"silence","delay_ms":2500,"action":"wait","label":"user-quiet","require_agent_spoke_first":true}],"verify":{"require_during_agent_speech":false,"min_agent_finals_after_silence":0}}}
// === Plugins (optional) ===
{"kind":"Plugins","spec":{"modules":[]}}
// === Assert (optional) — hard checks (tools / transcript / outcomes); fail run if not met ===
// tools[].name, min_count, args_contains
// transcript[].role, contains_any[], must_not_match (regex)
// outcomes[]: type transcript_contains | llm_bool (llm_bool needs judge:)
{"kind":"Assert","spec":{"tools":[],"transcript":[{"role":"agent","contains_any":["help","support","hello","hi"]}],"outcomes":[]}}
// === PassCriteria (optional) — soft LLM judge rubric; needs judge: in config.yaml ===
{"kind":"PassCriteria","spec":{"criteria":["The agent responded to the caller","The agent responded in a language the caller can understand"]}}
