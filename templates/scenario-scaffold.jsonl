// === Scenario (required header — first JSON line) ===
// apiVersion: must be "agent-sim/v1"
// metadata.id: same as this filename (without .jsonl)
// metadata.locale: BCP-47 language for the sim persona (e.g. en-US, vi-VN, ja-JP)
// metadata.tags: free labels; use with: lk-sim execute-all --tag smoke
{"apiVersion":"agent-sim/v1","kind":"Scenario","metadata":{"id":"{{SCENARIO_ID}}","locale":"en-US","tags":["draft"]}}
// === Persona (required) — Hamming-style character ===
// name, brief (required), goals[], style, traits[]
// constraints[]: hard rules (no card numbers, hang up if restart menu, …)
// speech_conditions: optional auto Script — barge_policy, noise, silence_ms
// language: optional override of metadata.locale for speech
{"kind":"Persona","spec":{"name":"Alex","brief":"You are calling a business for the first time. Confirm you reached the right place, answer briefly, then politely end the call when done.","goals":["Hear the agent greeting or first reply","State your reason briefly","End the call politely"],"style":"polite, brief, natural spoken language","traits":["polite"],"constraints":["Do not invent account numbers or payment details"],"speech_conditions":{"barge_policy":"","noise":"","silence_ms":0}}}
// === Context (optional) ===
// notes + optional fixtures (opaque hints for humans/seed; not parsed by core)
{"kind":"Context","spec":{"notes":"Example: open ticket #12345. Prefer deleting this line over leaving fake notes.","fixtures":{}}}
// === Simulator / Execute ===
{"kind":"Simulator","spec":{"max_turns":6,"timeout_s":120,"first_speaker":"agent"}}
{"kind":"Execute","spec":{"max_turns":4,"timeout_s":120,"first_speaker":"user"}}
// === Dispatch (optional) — opaque JSON string for RoomAgentDispatch.metadata ===
{"kind":"Dispatch","spec":{"metadata":"{\"yourProjectKey\":\"replace-me\"}"}}
// === Behavior (optional, Hamming policy) — compiles to Script if present ===
// barge_ins[], user_silence[], ambient{asset,delay_ms}
// Explicit Script below wins on same step id
// {"kind":"Behavior","spec":{"barge_ins":[{"id":"cut1","after_agent_ms":800,"say":"Wait — one second","with_blip":true}],"ambient":{"asset":"builtin:noise.ambient","delay_ms":5000}}}
// === Script (optional) — timed cues; omit if speech_conditions/Behavior enough ===
// trigger: agent_speaking | silence | time
// barge_in + with_blip (default true for gemini_text)
// asset: builtin:noise.loud | voice.barge_short | .agent-sim/cues/file.wav
// {"kind":"Script","spec":{"steps":[],"verify":{"require_during_agent_speech":false,"min_agent_finals_after_barge_in":0}}}
// === Assert — tools / transcript / outcomes (recovery | transcript_contains | llm_bool) ===
{"kind":"Assert","spec":{"tools":[],"transcript":[{"role":"agent","contains_any":["help","support","hello","hi"]}],"outcomes":[{"id":"agent_spoke","type":"transcript_contains","role":"agent","phrases":["a","e","i","o","u"]}]}}
// === PassCriteria (optional soft judge) ===
{"kind":"PassCriteria","spec":{"criteria":["The agent responded to the caller","The agent responded in a language the caller can understand"]}}
